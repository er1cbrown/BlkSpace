# BlkSpoof / BlkSpace
# Comprehensive .gitignore

# ============================================================================
# Dependencies
# ============================================================================
node_modules/
.pnpm-store/

# ============================================================================
# Build Outputs
# ============================================================================
dist/
build/
.vite/
*.tsbuildinfo
out-tsc/
tmp/
.expo/
.expo-shared/

# ============================================================================
# Rust / Tauri
# ============================================================================
src-tauri/target/
Cargo.lock
*.rs.bk

# ============================================================================
# IDE
# ============================================================================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.swp
*.swo
*~

# ============================================================================
# OS
# ============================================================================
.DS_Store
Thumbs.db

# ============================================================================
# Environment & Secrets
# ============================================================================
.env
.env.local
.env.*.local

# ============================================================================
# Logs
# ============================================================================
*.log
npm-debug.log*
yarn-error.log*
testem.log

# ============================================================================
# Package Managers
# ============================================================================
# pnpm-lock.yaml is tracked (deterministic installs)
# Do NOT ignore: pnpm-lock.yaml

# ============================================================================
# Coverage
# ============================================================================
/coverage
/libpeerconnection.log

# ============================================================================
# Misc
# ============================================================================
/.sass-cache
/connect.lock
/typings
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# ============================================================================
# Replit / Local
# ============================================================================
.cache/
.local/

# ============================================================================
# Assets that should not be tracked
# ============================================================================
attached_assets/

# ============================================================================
# Code-Companion specific
# ============================================================================
Code-Companion/.local/
Code-Companion/.cache/
Code-Companion/node_modules/
Code-Companion/**/node_modules/
Code-Companion/**/dist/
Code-Companion/**/target/
Code-Companion/**/*.tsbuildinfo

# ============================================================================
# Test artifacts
# ============================================================================
*.test.ts.snap
playwright-report/
test-results/

# ============================================================================
# Mobile (future)
# ============================================================================
*.apk
*.ipa
*.dmg
*.AppImage
*.msi
*.deb
*.rpm
