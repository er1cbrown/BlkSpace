{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BKSPC",
  "version": "0.1.0",
  "identifier": "com.blkspace.app",
  "build": {
    "frontendDist": "../dist/public",
    "devUrl": "http://127.0.0.1:24442",
    "beforeDevCommand": "PORT=24442 BASE_PATH=/ pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "BKSPC",
        "width": 1200,
        "height": 800,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' ws://localhost:* ws://127.0.0.1:* http://localhost:*; img-src 'self' data: https:; font-src 'self' data:; form-action 'self'",
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
