{
  "name": "@workspace/blkspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "PORT=24442 BASE_PATH=/ vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run --config vitest.config.ts",
    "test:iroh": "cargo test --manifest-path src-tauri/Cargo.toml --features iroh iroh_",
    "test:nostr-relay": "cargo test --manifest-path src-tauri/Cargo.toml nostr_relay_smoke -- --test-threads=1",
    "test:nostr-damus": "cargo test --manifest-path src-tauri/Cargo.toml nostr_publish_roundtrip_damus -- --test-threads=1",
    "test:tier0": "cargo test --manifest-path src-tauri/Cargo.toml tier0_benchmark --",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:no-iroh": "tauri build -- --no-default-features",
    "e2e": "node ./node_modules/@playwright/test/cli.js test --project=browser",
    "e2e:browser": "node ./node_modules/@playwright/test/cli.js test --project=browser",
    "e2e:tauri": "node e2e/run-tauri-e2e.mjs",
    "e2e:install": "playwright install chromium"
  },
